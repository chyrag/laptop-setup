;; ===== CONTEXT-AWARE REPLIES (Auto-detect account from headers) =====
(defun my/notmuch-set-account ()
  "Set SMTP account based on To/Cc/From headers."
  (let* ((to (message-fetch-field "To"))
         (cc (message-fetch-field "Cc"))
         (from (message-fetch-field "From"))
         (all-recipients (concat (or to "") " " (or cc "") " " (or from ""))))
    (cond
     ;; Gmail account
     ((string-match-p "chirag\\.kantharia@gmail\\.com" all-recipients)
      (setq user-mail-address "chirag.kantharia@gmail.com"
            user-full-name "Chirag Kantharia"
            smtpmail-smtp-server "smtp.gmail.com"
            smtpmail-smtp-service 587
            smtpmail-smtp-user "chirag.kantharia@gmail.com"
            smtpmail-stream-type 'starttls)
      (message "Using Gmail account"))

     ;; Yahoo account
     ((string-match-p "chyrag@yahoo\\.com" all-recipients)
      (setq user-mail-address "chyrag@yahoo.com"
            user-full-name "Chirag Kantharia"
            smtpmail-smtp-server "smtp.mail.yahoo.com"
            smtpmail-smtp-service 587
            smtpmail-smtp-user "chyrag@yahoo.com"
            smtpmail-stream-type 'starttls)
      (message "Using Yahoo account"))

     ;; Kantharia account
     ((string-match-p "chirag@kantharia\\.in" all-recipients)
      (setq user-mail-address "chirag@kantharia.in"
            user-full-name "Chirag Kantharia"
            smtpmail-smtp-server "mail.kantharia.in"
            smtpmail-smtp-service 993
            smtpmail-smtp-user "chirag"
            smtpmail-stream-type 'starttls)
      (message "Using Kantharia account"))

     ;; Default to Gmail if no match
     (t
      (setq user-mail-address "chirag.kantharia@gmail.com"
            user-full-name "Chirag Kantharia"
            smtpmail-smtp-server "smtp.gmail.com"
            smtpmail-smtp-service 587
            smtpmail-smtp-user "chirag.kantharia@gmail.com"
            smtpmail-stream-type 'starttls)
      (message "Using default Gmail account")))))

