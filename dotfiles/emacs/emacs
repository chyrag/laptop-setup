;; Set your preferred Nerd Font - try these in order of preference
;; Download from: https://www.nerdfonts.com/font-downloads
(defvar my/preferred-fonts
  '("MesloLGS Nerd Font"      ; Meslo - excellent for programming
    "MesloLGS NF"             ; Alternative name on some systems
    "SauceCodePro Nerd Font"  ; Source Code Pro variant
    "Hack Nerd Font"          ; Hack font
    "JetBrainsMono Nerd Font" ; JetBrains Mono
    "Menlo"                   ; macOS fallback
    "Consolas"                ; Windows fallback
    "DejaVu Sans Mono"))      ; Linux fallback

(defvar my/font-height (cond (my/is-macos 140)    ; macOS has higher DPI
                             (my/is-windows 140)
                             (t 200)))            ; Linux

(defun my/set-font ()
  "Set the first available font from the preferred list."
  (catch 'font-found
    (dolist (font my/preferred-fonts)
      (when (member font (font-family-list))
        (set-face-attribute 'default nil
                            :family font
                            :height my/font-height
                            :weight 'normal)
        (message "Using font: %s" font)
        (throw 'font-found font)))))

;; Set font after frame creation (needed for daemon mode)
(if (daemonp)
    (add-hook 'after-make-frame-functions
              (lambda (frame)
                (with-selected-frame frame (my/set-font))))
  (add-hook 'emacs-startup-hook #'my/set-font))

