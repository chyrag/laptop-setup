;;; ===========================================================================
;;; EARLY INIT - Performance Optimizations
;;; ===========================================================================

;; Increase garbage collection threshold during startup
(setq gc-cons-threshold (* 100 1024 1024))  ; 100MB during startup
(setq read-process-output-max (* 1024 1024)) ; 1MB for LSP

;; Reset GC threshold after startup
(add-hook 'emacs-startup-hook
          (lambda ()
            (setq gc-cons-threshold (* 20 1024 1024)))) ; 20MB normal operation

;;; ===========================================================================
;;; OS DETECTION
;;; ===========================================================================

(defconst my/is-windows (eq system-type 'windows-nt))
(defconst my/is-macos (eq system-type 'darwin))
(defconst my/is-linux (eq system-type 'gnu/linux))

;;; ===========================================================================
;;; PACKAGE MANAGEMENT
;;; ===========================================================================

(require 'package)
(setq package-archives
      '(("melpa" . "https://melpa.org/packages/")
        ("melpa-stable" . "https://stable.melpa.org/packages/")
        ("gnu" . "https://elpa.gnu.org/packages/")
        ("nongnu" . "https://elpa.nongnu.org/nongnu/")))

(package-initialize)

;; Bootstrap use-package
(unless (package-installed-p 'use-package)
  (package-refresh-contents)
  (package-install 'use-package))

(require 'use-package)
(setq use-package-always-ensure t)
(setq use-package-verbose t)

;;; ===========================================================================
;;; OS-SPECIFIC SETTINGS
;;; ===========================================================================

;; Windows-specific
(when my/is-windows
  (set-language-environment "UTF-8")
  (set-default-coding-systems 'utf-8)
  (set-terminal-coding-system 'utf-8)
  (set-keyboard-coding-system 'utf-8)
  (prefer-coding-system 'utf-8)

  ;; Git Bash for shell commands
  (when (file-exists-p "C:/Program Files/Git/bin/bash.exe")
    (setq explicit-shell-file-name "C:/Program Files/Git/bin/bash.exe")
    (setq shell-file-name "bash")
    (setq explicit-bash.exe-args '("--login" "-i"))
    (add-to-list 'exec-path "C:/Program Files/Git/bin")
    (add-to-list 'exec-path "C:/Program Files/Git/usr/bin"))

  ;; Prevent Windows from opening files in new frames
  (setq pop-up-frames nil)

  ;; Fix slow file operations on Windows
  (setq w32-get-true-file-attributes nil)

  ;; Native compilation settings
  (when (fboundp 'native-compile-async)
    (setq native-comp-async-report-warnings-errors nil)))

;; macOS-specific
(when my/is-macos
  ;; Use Command as Meta
  (setq mac-option-modifier 'meta)
  (setq mac-command-modifier 'super)

  ;; macOS ls doesn't support --dired
  (setq dired-use-ls-dired nil)

  ;; Add Homebrew paths
  (let ((homebrew-path (if (file-exists-p "/opt/homebrew/bin")
                           "/opt/homebrew/bin"    ; Apple Silicon
                         "/usr/local/bin")))      ; Intel
    (add-to-list 'exec-path homebrew-path)
    (setenv "PATH" (concat homebrew-path ":" (getenv "PATH"))))

  ;; Native compilation settings
  (when (fboundp 'native-compile-async)
    (setq native-comp-async-report-warnings-errors nil)))

;; Linux-specific
(when my/is-linux
  ;; Native compilation settings
  (when (fboundp 'native-compile-async)
    (setq native-comp-async-report-warnings-errors nil)))

;; Common UTF-8 settings for all platforms
(prefer-coding-system 'utf-8)
(set-default-coding-systems 'utf-8)

;;; ==========================================================================
;;; PATH CONFIGURATION (OS-independent)
;;; ==========================================================================

;; Add user-local bin directories to exec-path
(dolist (path (list
               (expand-file-name "~/bin")
               (expand-file-name "~/.local/bin")
               (expand-file-name "~/go/bin")
               (expand-file-name "~/.cargo/bin")
               (expand-file-name "~/.nix-profile/bin")))
  (when (file-directory-p path)
    (add-to-list 'exec-path path)
    (setenv "PATH" (concat path (if my/is-windows ";" ":") (getenv "PATH")))))

;;; ==========================================================================
;;; BASIC UI SETTINGS
;;; ==========================================================================

;; Disable startup screen
(setq inhibit-startup-screen t)
(setq inhibit-startup-message t)
(setq initial-scratch-message nil)

;; Disable GUI elements
(menu-bar-mode -1)    ;; Removes the top menu bar
(tool-bar-mode -1)    ;; Removes the toolbar
(scroll-bar-mode -1)  ;; Removes the vertical scrollbar
(tooltip-mode -1)     ;; Removes the hover tooltips
(set-fringe-mode 10)

;; Line numbers
(global-display-line-numbers-mode t)
(setq display-line-numbers-type 'relative)

;; Highlight current line
(global-hl-line-mode t)

;; Show column number in mode line
(column-number-mode t)

;; Show matching parentheses
(show-paren-mode t)
(setq show-paren-delay 0
