(use-package org
  :ensure nil  ; Built-in
  :hook ((org-mode . visual-line-mode)
         (org-mode . org-indent-mode))

  :init
  ;; Define custom variable before use-package processes :custom
  (defvar org-default-todo-file nil "Default file for TODO items.")
  (defvar org-journal-file nil "Journal")

  :config
  ;; Set the custom variable after org-directory is set
  (setq org-default-todo-file (expand-file-name "todo.org" org-directory)
	org-journal-file (expand-file-name "journal.org" org-directory)
	org-log-done 'time)
  (set-face-attribute 'org-agenda-date-today nil
		      :foreground "purple")
  (set-face-attribute 'org-scheduled-today nil
		      :foreground "#2a6b2a"
		      :weight 'bold)
  (set-face-attribute 'org-scheduled nil
		      :foreground "brown")
  (set-face-attribute 'org-done nil
		      :foreground "#8a8a8a"
		      :weight 'normal)
  (defun jump-to-org-agenda ()
    (interactive)
    (let ((buf (get-buffer "*Org Agenda*"))
          wind)
      (if buf
          (if (setq wind (get-buffer-window buf))
              (select-window wind)
            (if (called-interactively-p 'any)
                (progn
                  (select-window (display-buffer buf t t))
                  (org-fit-window-to-buffer))
              (with-selected-window (display-buffer buf)
                (org-fit-window-to-buffer))))
        ;; Use org-agenda with dashboard instead of org-agenda-list
        (org-agenda nil "d"))))
  (run-with-idle-timer 600 t 'jump-to-org-agenda)

  :custom
  ;; File locations
  (org-directory "~/Dropbox/Agenda/org/personal") ; for home
  (org-default-notes-file (concat org-directory "/notes.org"))
  (org-agenda-files (list org-directory))

  ;; Windows setup
  (org-agenda-window-setup 'only-window)
  (org-agenda-restore-windows-after-quit t)

  ;; Agenda settings
  (org-agenda-start-on-weekday nil)
  (org-agenda-start-day "-1d")
  (org-agenda-span 'fortnight)
  (org-agenda-skip-scheduled-if-done t)
  (org-agenda-skip-deadline-if-done t)
  (org-agenda-skip-deadline-prewarning-if-scheduled 'pre-scheduled)
  (org-agenda-include-diary t)
  (org-deadline-warning-days 7)
  (org-M-RET-my-split-line nil)

  ;; TODO keywords
  (org-todo-keywords
   '((sequence "TODO(t)" "IN-PROGRESS(i)" "WAITING(w)" "|" "DONE(d)" "CANCELLED(c)")))

  ;; Capture templates
  (org-capture-templates
   '(("t" "Todo" entry (file+headline org-default-todo-file "Tasks")
      "* TODO %?\n  %U\n  %a")
     ("n" "Note" entry (file+headline org-default-notes-file "Notes")
      "* %? :NOTE:\n  %U\n  %a")
     ("m" "Meeting" entry (file+headline org-default-notes-file "Meetings")
      "* %? :MEETING:\n  %U")
     ("j" "Journal" entry (file+headline org-journal-file "Journal")
      "* %? %^G\nEntered on %U\n" empty-lines 1)))

  ;; Visual settings
  (org-hide-emphasis-markers t)
  (org-pretty-entities t)
  (org-ellipsis " ▾")
  (org-src-fontify-natively t)
  (org-src-tab-acts-natively t)

  :bind
  (("C-c a" . org-agenda)
   ("C-c c" . org-capture)
   ("C-c l" . org-store-link)))

